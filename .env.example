# ── Vision model configuration ──────────────────────────────────────────────
# Copy to scripts/.env and fill in your values.

# API key (required)
VISION_API_KEY=sk-or-v1-your-key-here

# OpenAI-compatible base URL (default: OpenRouter)
VISION_BASE_URL=https://openrouter.ai/api/v1

# Vision model name
VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Max output tokens (default: 1024)
VISION_MAX_TOKENS=1024

# Auth header format: "Bearer" for OpenAI/OpenRouter,
# "x-api-key" for DeepSeek, "none" for no prefix
VISION_AUTH_HEADER=Bearer

# Extra JSON fields merged into request body (provider-specific params)
# VISION_EXTRA_BODY={"temperature": 0.7}
